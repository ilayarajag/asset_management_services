extends ../layout

block content
  .card
    .card-body
      h4 Asset History
      .table-responsive
        table.table.table-striped.table-bordered.datatable
          thead
            tr
              th Date
              th Asset
              th Employee
              th Action
              th Remarks
          tbody
            each item in history
              tr
                td= item.action_date
                td= item.Asset ? item.Asset.asset_uid : ''
                td= item.Employee ? item.Employee.employee_name : ''
                td= item.action
                td= item.remarks
