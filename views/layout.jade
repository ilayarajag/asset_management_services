doctype html
html
  head
    title= title
    link(rel='stylesheet', href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css')
    link(rel='stylesheet', href='https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css')
    style.
      body { padding-top: 20px; }
      .navbar-brand { font-weight: bold; }
      .card { margin-bottom: 20px; }
  body
    .container
      nav.navbar.navbar-expand-lg.navbar-dark.bg-dark.rounded.mb-4
        a.navbar-brand(href='/') Asset Management
        button.navbar-toggler(type='button', data-bs-toggle='collapse', data-bs-target='#nav')
          span.navbar-toggler-icon
        .collapse.navbar-collapse#nav
          ul.navbar-nav.me-auto
            li.nav-item
              a.nav-link(href='/') Dashboard
            li.nav-item
              a.nav-link(href='/employees') Employees
            li.nav-item
              a.nav-link(href='/assets') Assets
            li.nav-item
              a.nav-link(href='/categories') Categories
            li.nav-item
              a.nav-link(href='/stock') Stock
            li.nav-item
              a.nav-link(href='/issues/new') Issue
            li.nav-item
              a.nav-link(href='/returns/new') Return
            li.nav-item
              a.nav-link(href='/scrap') Scrap
            li.nav-item
              a.nav-link(href='/history') History
      block content
    script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js')
    script(src='https://code.jquery.com/jquery-3.7.1.min.js')
    script(src='https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js')
    script(src='https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js')
    script.
      $(document).ready(function(){ $('.datatable').DataTable(); });
