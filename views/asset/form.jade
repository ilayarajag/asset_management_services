extends ../layout

block content
  .card
    .card-body
      h4= title
      form(method='POST', action=asset.id ? '/assets/' + asset.id : '/assets')
        .row.g-3
          .col-md-6
            label.form-label Asset UID
            input.form-control(type='text', name='asset_uid', value=asset.asset_uid, required)
          .col-md-6
            label.form-label Serial Number
            input.form-control(type='text', name='serial_no', value=asset.serial_no, required)
          .col-md-6
            label.form-label Category
            select.form-select(name='category_id')
              each category in categories
                option(value=category.id, selected=asset.category_id == category.id)= category.category_name
          .col-md-6
            label.form-label Branch
            input.form-control(type='text', name='branch', value=asset.branch)
          .col-md-6
            label.form-label Make
            input.form-control(type='text', name='make', value=asset.make)
          .col-md-6
            label.form-label Model
            input.form-control(type='text', name='model', value=asset.model)
          .col-md-6
            label.form-label Purchase Date
            input.form-control(type='date', name='purchase_date', value=asset.purchase_date)
          .col-md-6
            label.form-label Purchase Price
            input.form-control(type='number', step='0.01', name='purchase_price', value=asset.purchase_price)
          .col-md-6
            label.form-label Status
            select.form-select(name='status')
              option(value='Available', selected=asset.status === 'Available') Available
              option(value='Issued', selected=asset.status === 'Issued') Issued
              option(value='Returned', selected=asset.status === 'Returned') Returned
              option(value='Scrapped', selected=asset.status === 'Scrapped') Scrapped
        .mt-3
          button.btn.btn-primary(type='submit') Save
          a.btn.btn-secondary.ms-2(href='/assets') Cancel
